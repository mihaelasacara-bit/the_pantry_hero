<div class="container py-4">
  <%= link_to "← Meal plans", meal_plans_path, id: "backLink" %>

  <h1 class="mb-4"><%= @meal_plan.start_date %> Meal Plan</h1>

  <%= link_to "Edit Meal Plan", edit_meal_plan_path(@meal_plan), class: "btn btn-outline-primary mb-3" %>

  <% if @meal_plan.recipes.empty? %>
    <%= button_to "Create Chat with Assistant", meal_plan_chats_path(@meal_plan), method: :post, class: "btn btn-success mb-4" %>
  <% end %>

  <% @meal_plan.recipes.order(:recipe_day).each do |recipe| %>
    <div class="card mb-3 rounded-4">
      <div class="card-body">
        <h5 class="card-title">Day <%= recipe.recipe_day %></h5>
        <p class="card-text mb-2"><strong>Ingredients:</strong> <%= recipe.ingredients %></p>
        <p class="card-text mb-0"><strong>Instructions:</strong> <%= recipe.instructions %></p>
      </div>
    </div>
  <% end %>
</div>
