<div class="container mt-5">
  <h1>My Meal Plans</h1>
  <div class="row">
    <div class="col-md-4 mb-3">
      <%# <div class="card p-3"> %>
        <%= link_to "Create meal plan", new_meal_plan_path, class: "btn btn-success" %>
      <%# </div> %>
    </div>
  </div>
  <div class="row">
    <% @meal_plans.each do |plan| %>
      <div class="col-md-4 mb-3">
        <div class="card text-white mb-3" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1498837167922-ddd27525d352?w=800&auto=format&fit=crop'); background-size: cover; background-position: center; border-radius: 8px; min-height: 200px;">
          <div class="card-body d-flex flex-column justify-content-between">
            <h5 class="card-title">Plan #<%= plan.id %></h5>
            <%= link_to "View Details", meal_plan_path(plan), class: "btn btn-outline-light" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
