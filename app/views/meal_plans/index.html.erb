<h1>My Meal Plans</h1>
<div class="container mt-5">
  <h1>My Meal Plans</h1>
  <div class="row">
    <% @meal_plans.each do |plan| %>
      <div class="col-md-4 mb-3">
        <div class="card p-3">
          <p>Plan #<%= plan.id %></p>
          <%= link_to "View Details", meal_plan_path(plan), class: "btn btn-outline-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>