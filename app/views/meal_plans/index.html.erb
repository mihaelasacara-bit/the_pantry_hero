<div class="container mt-5">
  <%= link_to "← Home", root_path, id: "backLink" %>
  <h1>My Meal Plans</h1>
  <div class="row">
    <div class="col-md-4 mb-3">
      <%# <div class="card p-3"> %>
        <%= link_to "Create meal plan", new_meal_plan_path, class: "btn btn-success" %>
      <%# </div> %>
    </div>
  </div>
  <div class="row">
    <% @meal_plans.each do |plan| %>
      <div class="col-md-4 mb-3">
        <div class="card p-3">
            <% if plan.title.present? %>
              <h5 class="card-title"><%= plan.title %></h5>
            <% else %>
              <h5 class="card-title text-muted">Plan #<%= plan.id %></h5>
            <% end %>
          <%= link_to "View Details", meal_plan_path(plan), class: "btn btn-outline-success" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
