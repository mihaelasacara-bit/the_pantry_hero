<%= turbo_stream_from @chat %>
<div class="container py-4">
  <%= link_to "← Meal plan", meal_plan_path(@chat.meal_plan), id: "backLink" %>
  <div class="row mt-3">
    <div class="col">
      <h1><%= @meal_plan.start_date %> Meal plan</h1>
    </div>
    <div id="messages">
      <% if @chat.messages.count == 0 %>
        <p class="text-muted">Enter a message to start talking with the AI agent.</p>
      <% else %>
        <%= render @chat.messages %>
      <% end %>
    </div>
    <div class="row mb-2">
      <div class="col-auto p-3 m-3 d-flex justify-content-start rounded-5" id="mealPlanButton">
        <%= link_to "See your meal plan", meal_plan_path(@chat.meal_plan) %>
      </div>
    </div>
    <div id="new_message_container" class="col input-group mb-3">
      <%= render "messages/form", chat: @chat, message: @message %>
    </div>
  </div>
</div>
