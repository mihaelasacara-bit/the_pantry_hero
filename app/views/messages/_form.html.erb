<div class="container mt-3">
  <%= simple_form_for [chat, message] do |f| %>
    <% placeholder_text = chat.messages.count == 0 ? "Help me get a meal plan for next week" : "Add a new message" %>

    <%= f.input :content,
                label: chat.messages.count == 0 ? "What’s your main goal with this meal plan — are you trying to eat healthier, save time during the week, reduce food waste, or something else?" : false,
                required: true,
                placeholder: placeholder_text %>
    <%= f.button :submit, 'Ask Pantry Hero', class: 'btn btn-outline-success'  %>
  <% end %>
</div>
