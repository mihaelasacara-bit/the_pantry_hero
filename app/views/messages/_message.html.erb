<% if message.role == "user" %>
  <div class="row d-flex justify-content-end mb-2">
    <div class="col-auto bg-white p-3 rounded-5">
      <%= message.content %>
    </div>
  </div>
  <% elsif message.role == "assistant" %>
    <div class="col-auto d-flex justify-content-start p-3 rounded-5 assitantChat" id="<%= dom_id(message)%>">
      <%= message.content.present? ? raw(render_markdown(message.content)) : "Pantry Hero is thinking..." %>
    </div>
<% end %>
